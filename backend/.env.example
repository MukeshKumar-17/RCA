# ──────────────────────────────────────────────────────────
#  RootLens AI — Environment Configuration Example
# ──────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/rootlens

# Google Gemini API key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Gemini multi-key pool (round-robin with 429 fallback)
GEMINI_API_KEY_1=your_gemini_api_key_account_1
GEMINI_API_KEY_2=your_gemini_api_key_account_2
GEMINI_API_KEY_3=your_gemini_api_key_account_3

# InsForge backend URL
MCP_INFORGE_URL=https://your-app.us-east.insforge.app

# InsForge anon key
INFORGE_KEY=ik_your_inforge_key_here

# Local upload directory
UPLOAD_DIR=./storage

# Secret key for signing tokens
SECRET_KEY=your-secret-key-here

# SMTP settings (for email feature — legacy)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password123

# SendGrid email (verify sender at SendGrid Settings → Sender Authentication)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxx
EMAIL_FROM=your_verified_sender_email

# Legacy (deprecated — no longer used)
OPENROUTER_API_KEY=
LLM_MODEL=gemini-2.5-flash
