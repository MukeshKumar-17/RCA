# ──────────────────────────────────────────────────────────
#  RootLens AI — .gitignore
# ──────────────────────────────────────────────────────────

# ── Secrets & Environment Variables ────────────────────────
# NEVER commit real credentials
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# ── Dependencies ───────────────────────────────────────────
node_modules/

# ── Build Outputs ──────────────────────────────────────────
dist/
dist-ssr/
build/
.vite/

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
venv/
.venv/
env/
.pytest_cache/
coverage/
*.egg

# ── InsForge & Platform ────────────────────────────────────
.insforge/

# ── AI Agent / Coding Assistant configs ────────────────────
.agent
.agents
.augment
.claude
.cline
.github/copilot*
.kilocode
.qoder
.qwen
.roo
.trae
.windsurf
.gemini/

# ── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor & IDE ───────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS Files ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Local Data & Temporary Files ──────────────────────────
storage/
temp/
backend_clean/
recovered/
sample-data/

# ── PDFs & Generated Exports ──────────────────────────────
*.pdf

# ── SQL Migration Scripts (may contain DB credentials) ────
fix_*.sql
schema_update.sql

# -- Misc -------------------------------------------------------
*.local
AGENTS.md
migrate.py

# ── Databases & Credentials ───────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.pem
*.key
*.cert
*.crt
credentials.json
client_secret.json
secrets.json
